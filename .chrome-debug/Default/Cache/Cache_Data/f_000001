  .rc-summary div{text-align:center}
  .grade-row{padding:8px;gap:10px}
  .grade-pill{padding:4px 8px;font-size:11px}
  
  /* MODAL */
  .modal-overlay{padding:16px}
  .modal-overlay .card{max-width:100%;border-radius:16px}
  
  /* NOTICE */
  .notice-item{gap:10px;padding:12px;display:flex;flex-direction:column}
  .notice-icon{width:40px;height:40px}
  .notice-content h4{font-size:12px}
  .notice-content p{font-size:10px}
  
  /* PAGINATION */
  .pg-btn{width:28px;height:28px;font-size:10px}
  
  /* SEARCH */
  .input-search{min-width:auto;flex:1}
  .search-bar{max-width:100%}
  
  /* TOOLBAR */
  .toolbar{gap:6px;margin-bottom:12px}
  .select-sm{padding:8px 10px;padding-right:32px;font-size:11px}
  
  /* TABLES */
  .tbl{
    font-size:12px;
    table-layout:auto;
    min-width:100%;
  }
  /* Materials-specific responsive tweaks inside g21 layout */
  .g21 .card{padding:14px}
  @media (max-width:768px){
    .g21{gap:10px}
    .g21 .card{padding:12px}
