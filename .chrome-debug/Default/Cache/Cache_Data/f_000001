  .role-switcher{bottom:72px;right:16px;min-width:160px;padding:12px}
  .rs-title{font-size:9px}
  .rs-item{padding:6px 8px;font-size:11px}
  
  /* TOAST */
  .toast{padding:12px 14px;border-radius:8px;font-size:12px;min-width:auto;max-width:calc(100vw - 32px)}
  
  /* BREADCRUMB */
  .breadcrumb{font-size:10px}
  
  /* MODULE TABS */
  .mod-tabs{gap:3px;margin-bottom:16px}
  .mod-tab{padding:6px 12px;font-size:11px;border-radius:8px}
  
  /* HERO SECTIONS */
  .visitor-hero{padding:40px 24px;border-radius:16px;margin-bottom:16px}
  .visitor-hero h1{font-size:28px;margin-bottom:8px}
  .visitor-hero p{font-size:13px;margin-bottom:16px}
  .hero-btns{gap:8px}
  .hero-btn-gold,.hero-btn-outline{padding:10px 16px;font-size:12px}
  .visitor-hero-photo{min-height:340px}
  .hero-slide-item{grid-template-columns:1fr;align-items:start}
  .hero-slide-thumb{width:100%}
  .newspaper-article{padding:22px}
  .newspaper-article h1{font-size:28px}
  .newspaper-body{columns:1}
  
  /* FORMS IN MODALS */
  .f-field input:focus,.f-field select:focus,.f-field textarea:focus{
    box-shadow:0 0 0 2px rgba(26,86,219,.08);
  }
}

/* SMALL MOBILE SCREENS (Below 480px) */
@media (max-width:480px){
  :root{
    --sidebar-w:0;
    --topbar-h:52px;
  }
  
  html,body{
    font-size:13px;
    overflow-x:hidden;
    width:100%;
    max-width:100vw;
  }
  
  /* PREVENT HORIZONTAL SCROLLING - but allow tables to scroll */
  html,body,main,nav,.sidebar,.card,.main-wrap,.footer,.page-hdr,.stats-row{
    overflow-x:hidden !important;
    max-width:100vw !important;
  }
  
  /* ALLOW TABLES TO SCROLL HORIZONTALLY */
  .table-wrapper{
    overflow-x:auto !important;
    overflow-y:visible;
    max-width:100% !important;
  }
  
  /* TOPBAR */
  .topbar{padding:0 8px;height:52px;overflow-x:visible;max-width:100vw;}
  .brand-mark{width:28px;height:28px;font-size:12px}
  .brand-mark i{font-size:14px}
  .brand-name{display:none}
  .brand-tag{display:none}
  .brand-info{flex-shrink:0}
  .tb-btn{width:32px;height:32px;font-size:12px}
  .tb-avatar{width:32px;height:32px;font-size:10px}
  .role-chip{display:none}
  
  /* MAIN CONTENT */
  .main-wrap{padding:12px;padding-top:calc(52px + 12px)}
  
  /* PAGE HEADER */
  .page-hdr h1{font-size:18px;margin-bottom:2px}
  .page-hdr p{font-size:10px}
  
  /* STATS */
  .stat-card{padding:12px 14px}
  .stat-icon{width:36px;height:36px;font-size:18px;margin-bottom:8px}
  .stat-val{font-size:20px;letter-spacing:-.3px}
  .stat-lbl{font-size:9px}
  
  /* CARDS */
  .card{padding:14px}
  .card-title{font-size:12px}
  
  /* BUTTONS */
  .btn{padding:7px 12px;font-size:10px}
  
  /* FORMS */
  .f-field input,.f-field select,.f-field textarea{
    padding:7px 9px;font-size:10px;
  }
  
  /* LOGIN */
  .login-wrapper{border-radius:16px;padding:24px 16px}
  .role-grid{grid-template-columns:1fr;gap:8px}
  .role-btn{padding:10px 4px}
  .role-btn .ri{font-size:18px}
  .role-btn .ri i{font-size:18px}
  .role-btn .rl{font-size:8px}
  
  /* TABLES */
  .tbl{
    font-size:11px;
    table-layout: auto;
    min-width:100%;
  }
  .tbl th{
    padding:8px 10px;
    font-size:9px;
    white-space:nowrap;
    background:var(--white);
    position:sticky;
    top:0;
    border-bottom:1.5px solid var(--gray-200);
  }
  .tbl td{
    padding:8px 10px;
    font-size:10px;
    word-break:break-word;
    overflow-wrap:break-word;
    border-bottom:1px solid var(--gray-100);
    max-width:200px;
  }
  
  /* FOOTER */
  .footer{padding:10px 12px;font-size:9px}
  
  /* PUBLIC NAVBAR */
  .public-navbar{height:56px;padding:0 8px}
  .public-brand .brand-mark{width:32px;height:32px;font-size:14px}
  .public-brand .brand-mark i{font-size:16px}
  
  /* MODAL */
  .modal-overlay{padding:12px}
  
  /* RADIO AND CHECKBOX SIZING */
  input[type="checkbox"],
  input[type="radio"]{
    width:16px;height:16px;
  }
}

/* LANDSCAPE MODE ADJUSTMENTS */
@media (max-width:768px) and (orientation:landscape){
  :root{
    --topbar-h:48px;
  }
  
  .topbar{height:48px}
  .sidebar{top:48px}
  .main-wrap{padding-top:calc(48px + 16px);min-height:calc(100vh - 48px)}
  
  .page-hdr h1{font-size:16px;margin-bottom:4px}
  .stats-row{gap:10px;margin-bottom:16px}
  .stat-card{padding:12px 14px}
  .stat-icon{width:36px;height:36px;font-size:18px;margin-bottom:6px}
  .stat-val{font-size:18px}
  
  .g2,.g3,.g4{grid-template-columns:repeat(2,1fr);gap:10px}
  
  .card{padding:12px}
  .card-title{font-size:12px}
  
  .login-left{padding:20px}
  .login-right{padding:20px}
  .login-left h1{font-size:18px}
}

/* EXTRA LARGE SCREENS (2K and above - 1920px+) */
@media (min-width:1920px){
  :root{
    --sidebar-w:260px;
  }
  
  .main-wrap{padding:40px;padding-left:calc(40px + var(--sidebar-w))}
  .footer{margin-left:var(--sidebar-w)}
  
  .page-hdr h1{font-size:28px}
  .stats-row{grid-template-columns:repeat(5,1fr)}
  .g3{grid-template-columns:repeat(4,1fr)}
  .g4{grid-template-columns:repeat(5,1fr)}
  
  .stat-val{font-size:32px}
  .card{padding:28px}
  
  .gal-grid{grid-template-columns:repeat(4,1fr)}
  
  .rc-summary{grid-template-columns:repeat(6,1fr)}
  
  .topbar-search{max-width:450px}
}

/* HIDEABLE SIDEBAR TOGGLE */
.sidebar-toggle{
  display:none;
  position:fixed;
  top:8px;left:8px;
  z-index:350;
  background:var(--blue-main);
  color:#fff;
  border:none;
  width:40px;height:40px;
  border-radius:8px;
  cursor:pointer;
  font-size:18px;
  align-items:center;
  justify-content:center;
  box-shadow:0 2px 8px rgba(0,0,0,.15);
}

@media (max-width:768px){
  .sidebar-toggle{display:flex}
}

.sidebar-toggle:active{transform:scale(0.95)}

/* ═══════════════════ STUDENT PROFILE CARD ═══════════════════ */
.student-profile-card{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:20px 24px;
  background:linear-gradient(135deg,var(--blue-xpale),var(--blue-pale));
  border-radius:var(--radius-lg);
  border:1.5px solid var(--blue-light);
  margin-bottom:24px;
  box-shadow:0 2px 8px rgba(26,86,219,.08);
}

.profile-left{
  display:flex;
  gap:16px;
  align-items:center;
}

.profile-info{
  display:flex;
  flex-direction:column;
  gap:2px;
}

.profile-name{
  font-size:18px;
  font-weight:700;
  color:var(--blue-dark);
  margin:0;
}

.profile-id{
  font-size:13px;
  color:var(--gray-600);
  margin:0;
}

.profile-class{
  font-size:12px;
  color:var(--gray-500);
  margin:0;
}

.profile-idcard-btn{
  display:flex;
  align-items:center;
  justify-content:center;
  width:48px;
  height:48px;
  border-radius:50%;
  background:var(--blue-main);
  color:white;
  border:none;
  cursor:pointer;
  font-size:24px;
  transition:all 0.3s ease;
  box-shadow:0 2px 8px rgba(26,86,219,.25);
}

.profile-idcard-btn:hover{
  background:var(--blue-dark);
  transform:scale(1.05);
  box-shadow:0 4px 12px rgba(26,86,219,.35);
}

.profile-idcard-btn:active{
  transform:scale(0.98);
}

/* ═══════════════════ ID CARD MODAL ═══════════════════ */
.idcard-modal-overlay{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.5);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:1000;
  animation:fadeIn 0.3s ease;
  -webkit-backdrop-filter:blur(2px);
  backdrop-filter:blur(2px);
  padding:20px;
}

@keyframes fadeIn{
  from{opacity:0}
  to{opacity:1}
}

.idcard-modal-content{
  position:relative;
  background:white;
  border-radius:var(--radius-lg);
  max-width:700px;
  width:100%;
  max-height:90vh;
  overflow-y:auto;
  box-shadow:var(--shadow-xl);
  animation:slideUp 0.3s ease;
}

@keyframes slideUp{
  from{transform:translateY(20px);opacity:0}
  to{transform:translateY(0);opacity:1}
}

.idcard-close-btn{
  position:absolute;
  top:12px;
  right:12px;
  background:none;
  border:none;
  font-size:28px;
  color:var(--gray-500);
  cursor:pointer;
  width:36px;
  height:36px;
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:10;
  transition:color 0.2s;
}

.idcard-close-btn:hover{
  color:var(--danger);
}

.idcard-container{
  padding:0;
  display:flex;
  flex-direction:column;
}

/* THE ACTUAL ID CARD DESIGN */
.idcard-actual-card{
  background:
    url("data:image/svg+xml,%3Csvg width='140' height='140' viewBox='0 0 140 140' xmlns='http://www.w3.org/2000/svg'%3E%3Ctext x='70' y='70' font-family='Arial, sans-serif' font-size='80' fill='%231a56db' opacity='0.08' text-anchor='middle' dominant-baseline='middle'%3E%F0%9F%8F%AB%3C/text%3E%3C/svg%3E") repeat,
    linear-gradient(135deg,var(--white) 0%,#fafbfc 100%);
  background-attachment: fixed;
  border:3px solid var(--blue-main);
  border-radius:14px;
  padding:28px 24px;
  margin:20px;
  aspect-ratio:16/10;
  display:flex;
  flex-direction:column;
  gap:16px;
  box-shadow:0 8px 24px rgba(26,86,219,.15);
  position:relative;
  overflow:hidden;
}

.idcard-actual-card::before{
  content:'';
  position:absolute;
  top:0;
  left:0;
  right:0;
  height:3px;
  background:linear-gradient(90deg,var(--blue-main),var(--blue-dark));
}

.idcard-actual-card::after{
  content:'';
  position:absolute;
  bottom:0;
  left:0;
  right:0;
  height:2px;
  background:linear-gradient(90deg,var(--blue-dark),var(--blue-main));
}

.idcard-top-section{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:8px;
  padding-bottom:12px;
  border-bottom:2px solid var(--blue-main);
  text-align:center;
}

.idcard-logo-section{
  width:48px;
  height:48px;
  border-radius:50%;
  background:white;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:26px;
  color:var(--blue-dark);
  box-shadow:0 2px 8px rgba(26,86,219,.3);
}

.idcard-school-name{
  font-size:14px;
  font-weight:700;
  color:var(--blue-dark);
  letter-spacing:0.5px;
}

.idcard-card-title{
  font-size:16px;
  font-weight:800;
  color:var(--gray-800);
  letter-spacing:2px;
}

.idcard-main-body{
  display:grid;
  grid-template-columns:1.5fr 1fr;
  gap:20px;
  align-items:center;
  flex:1;
}

.idcard-info-section{
  display:flex;
  flex-direction:column;
  gap:12px;
}

.idcard-info-item{
  display:flex;
  flex-direction:column;
  gap:2px;
}

.idcard-info-label{
  font-size:11px;
  font-weight:700;
  color:var(--gray-600);
  text-transform:uppercase;
  letter-spacing:0.8px;
}

.idcard-info-value{
  font-size:15px;
  font-weight:700;
  color:var(--blue-dark);
}

.idcard-photo-section{
  display:flex;
  align-items:center;
  justify-content:center;
  height:100%;
}

.idcard-photo{
  width:120px;
  height:140px;
  background:linear-gradient(135deg,var(--blue-pale),var(--blue-xpale));
  border-radius:8px;
  display:flex;
  align-items:center;
  justify-content:center;
  border:3px solid var(--blue-light);
  box-shadow:0 2px 8px rgba(26,86,219,.2);
}

.idcard-avatar{
  width:100px;
  height:120px;
  font-size:32px;
  font-weight:700;
}

.idcard-footer{
  padding:16px 24px;
  background:var(--gray-50);
  border-top:1px solid var(--gray-200);
  text-align:center;
}

.idcard-footer p{
  font-size:10px;
  color:var(--gray-600);
  margin:0 0 12px 0;
}

.idcard-footer .btn{
  width:auto;
  padding:8px 24px;
  justify-content:center;
}

/* RESPONSIVE ID CARD */
@media (max-width:768px){
  .idcard-modal-overlay{
    padding:10px;
  }
  
  .idcard-modal-content{
    max-width:100%;
  }
  
  .idcard-actual-card{
    margin:16px;
    padding:20px 16px;
    gap:12px;
    aspect-ratio:auto;
    min-height:400px;
  }
  
  .idcard-top-section{
    gap:6px;
    padding-bottom:10px;
  }
  
  .idcard-logo-section{
    width:40px;
    height:40px;
    font-size:20px;
  }
  
  .idcard-school-name{
    font-size:12px;
  }
  
  .idcard-card-title{
    font-size:14px;
    letter-spacing:1.5px;
  }
  
  .idcard-main-body{
    grid-template-columns:1fr;
    gap:14px;
  }
  
  .idcard-info-section{
    gap:10px;
  }
  
  .idcard-info-label{
    font-size:10px;
  }
  
  .idcard-info-value{
    font-size:14px;
  }
  
  .idcard-photo-section{
    justify-content:center;
  }
  
  .idcard-photo{
    width:100px;
    height:120px;
  }
  
  .idcard-avatar{
    width:80px;
    height:100px;
    font-size:24px;
  }
}

/* ── Accessibility utility ── */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

