}
.archived-teachers-table th:nth-child(2),
.archived-teachers-table td:nth-child(2){width:210px}
.archived-teachers-table th:nth-child(3),
.archived-teachers-table td:nth-child(3){width:82px}
.archived-teachers-table th:nth-child(4),
.archived-teachers-table td:nth-child(4){width:230px}
.archived-teachers-table th:nth-child(5),
.archived-teachers-table td:nth-child(5){width:150px}
.archived-teachers-table th:nth-child(6),
.archived-teachers-table td:nth-child(6){width:140px}
.archived-teachers-table th:nth-child(7),
.archived-teachers-table td:nth-child(7){width:170px}
.archived-teachers-table th:nth-child(8),
.archived-teachers-table td:nth-child(8){width:220px}
.archived-teachers-table th:nth-child(9),
.archived-teachers-table td:nth-child(9){width:150px}
.student-actions-cell{
  width:76px;
  min-width:76px;
  max-width:76px !important;
  overflow:visible !important;
  position:relative;
}
.row-action-menu{
  position:relative;
  display:inline-flex;
  justify-content:center;
}
.row-action-menu summary{
  list-style:none;
  width:34px;
  height:34px;
  border:1px solid var(--gray-200);
  border-radius:10px;
  background:var(--white);
  color:var(--blue-main);
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  transition:all .16s ease;
}
.row-action-menu summary::-webkit-details-marker{display:none}
.row-action-menu summary:hover,
.row-action-menu[open] summary{
  background:var(--blue-main);
  border-color:var(--blue-main);
  color:#fff;
  box-shadow:0 8px 18px rgba(26,86,219,.18);
}
.row-action-list{
  position:absolute;
  right:0;
  top:40px;
  z-index:80;
  min-width:150px;
  padding:6px;
  border:1px solid var(--gray-200);
  border-radius:12px;
  background:var(--white);
  box-shadow:0 16px 34px rgba(15,23,42,.16);
  display:grid;
  gap:4px;
}
.row-action-list button{
  border:0;
  background:transparent;
  color:var(--gray-700);
  border-radius:8px;
  padding:9px 10px;
  display:flex;
  align-items:center;
  gap:8px;
  font-family:'Poppins',sans-serif;
  font-size:12px;
  font-weight:700;
  text-align:left;
  cursor:pointer;
}
.row-action-list button:hover{
  background:var(--blue-xpale);
  color:var(--blue-main);
}
.row-action-list button.danger{
  color:var(--danger);
}
.row-action-list button.danger:hover{
  background:var(--danger-light);
}
.pie-svg text{font-family:'Poppins',sans-serif}

/* GALLERY GRID */
.gal-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.gal-item{aspect-ratio:4/3;border-radius:var(--radius-lg);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;border:1px solid var(--gray-200);transition:transform .2s,box-shadow .2s;overflow:hidden;position:relative}
.gal-item:hover{transform:scale(1.02);box-shadow:var(--shadow)}
.gal-item .gi-icon{font-size:36px}
.gal-item .gi-label{font-size:11px;color:var(--gray-600);margin-top:8px;text-align:center;font-weight:500;padding:0 10px}

/* REPORT CARD STYLES */
.report-card-container{max-width:900px;margin:0 auto}
.rc-wrap{background:white;border-radius:var(--radius-lg);box-shadow:var(--shadow-lg);padding:40px;line-height:1.6}
.rc-header{text-align:center;border-bottom:3px solid var(--blue-main);padding-bottom:20px;margin-bottom:30px}
.rc-header h1{font-size:28px;font-weight:800;color:var(--blue-dark);margin:8px 0}
.rc-header p{color:var(--gray-500);margin:4px 0}
.rc-student{display:flex;gap:24px;padding:20px;background:var(--blue-xpale);border-radius:var(--radius)}
.rc-summary{display:grid;grid-template-columns:repeat(5,1fr);gap:16px;padding:20px;background:var(--gray-50);border-radius:var(--radius)}
.rc-summary div{text-align:center}
.grade-row{display:flex;align-items:center;padding:12px;border-bottom:1px solid var(--gray-200);gap:16px}
.grade-pill{padding:6px 14px;border-radius:6px;font-weight:700;color:white;font-size:13px}
.grade-pill.gA{background:var(--success)}
.grade-pill.gB{background:var(--info)}
.grade-pill.gC{background:var(--warning)}
.grade-pill.gD,.grade-pill.gE{background:var(--danger)}
.grade-pill.gF{background:#dc2626}

@media print{
  body,html{margin:0;padding:0;background:white}
  .main-wrap,.sidebar,.topbar,.footer,.navbar{display:none !important}
  .report-card-container{margin:0;padding:0}
  .rc-wrap{box-shadow:none;border:none;padding:20px}
  .btn{display:none !important}
}

/* DARK MODE - COMPREHENSIVE STYLING */
body.dark{
  --white:#111827;
  --gray-50:#0b1220;
  --gray-100:#111827;
  --gray-200:#1f2937;
  --gray-300:#334155;
  --gray-400:#94a3b8;
  --gray-500:#cbd5e1;
  --gray-600:#dbe3ef;
  --gray-700:#e5edf7;
  --gray-800:#f1f5f9;
  --gray-900:#f8fafc;
  --blue-dark:#c7dff5;
  --blue-main:#7aa7d9;
  --blue-mid:#5d86b7;
  --blue-light:#456f9e;
  --blue-pale:#223a55;
  --blue-xpale:#152538;
  --gold:#fbbf24;
  --gold-dark:#f59e0b;
  --gold-light:#fde68a;
  --gold-xlight:#3f2f12;
  --success-light:rgba(16,185,129,.16);
  --danger-light:rgba(239,68,68,.16);
  --warning-light:rgba(245,158,11,.18);
