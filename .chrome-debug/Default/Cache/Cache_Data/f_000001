/* TOAST NOTIFICATIONS */
.toast{
  padding:14px 18px;border-radius:10px;font-size:13px;font-weight:500;
  box-shadow:0 8px 24px rgba(0,0,0,0.15);display:flex;align-items:center;
  gap:10px;min-width:280px;max-width:400px;word-wrap:break-word;
  animation-duration:0.3s;animation-fill-mode:forwards;
}

.toast-success{
  background:linear-gradient(135deg,#7bbca6,#42f1ba);color:#101010;
  border-left:4px solid #047857;
}

.toast-success::before{
  content:'';font-size:18px;flex-shrink:0;
}

.toast-error{
  background:linear-gradient(135deg,#e0bcbc,#f59191);color:#070707;
  border-left:4px solid #991b1b;
}

.toast-error::before{
  content:'';font-size:18px;flex-shrink:0;
}

.toast-warning{
  background:linear-gradient(135deg,#f59e0b,#d97706);color:#fff;
  border-left:4px solid #92400e;
}

.toast-warning::before{
  content:'';font-size:18px;flex-shrink:0;
}

.toast-info{
  background:linear-gradient(135deg,#3b82f6,#2563eb);color:#fff;
  border-left:4px solid #1e40af;
}

.toast-info::before{
  content:'';font-size:18px;flex-shrink:0;
}

@keyframes slideInRight{
  from{transform:translateX(400px);opacity:0}
  to{transform:translateX(0);opacity:1}
}

@keyframes slideOutRight{
  from{transform:translateX(0);opacity:1}
  to{transform:translateX(400px);opacity:0}
}

/* ═══════════════════════════════════ UNIVERSAL SELECT STYLING ═══════════════════════════════════ */

/* Default enhanced select styling for all selects */
select{
  -webkit-appearance:none;-moz-appearance:none;appearance:none;
  cursor:pointer;
}

/* Enhanced styling for generic input-based selects */
.input-base[type="text"],
.input-base[type="email"],
.input-base[type="tel"],
select:not(.form-field select):not(.select-sm)[style*="width:100%"],
select:not(.form-field select):not(.select-sm)[style*="padding:10px"]{
  -webkit-appearance:none;-moz-appearance:none;appearance:none;
  padding-right:36px;
  background-image:url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23475569' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
  background-repeat:no-repeat;background-position:right 10px center;background-size:18px;
}

/* Stylized select button appearance */
.select-btn{
  display:inline-flex;align-items:center;gap:8px;padding:10px 16px;
  border:1.5px solid var(--gray-200);border-radius:var(--radius);
  background:var(--white);color:var(--gray-700);font-size:13px;font-weight:500;
  cursor:pointer;transition:all 0.2s;font-family:'Poppins',sans-serif;
}

.select-btn:hover{
  border-color:var(--blue-light);background:var(--blue-xpale);box-shadow:0 2px 8px rgba(26,86,219,.08);
}

.select-btn::after{
  content:'▼';font-size:11px;margin-left:auto;opacity:0.7;
}

/* Dropdown indicator styling */
.dropdown-indicator{
  display:inline-flex;align-items:center;gap:4px;font-size:13px;color:var(--gray-600);font-weight:500;
}

.dropdown-indicator::after{
  content:'▼';font-size:10px;opacity:0.6;
}

/* Dark mode select enhancements */
body.dark select:not(.form-field select):not(.select-sm){
  background-color:#334155;color:#e2e8f0;
  border-color:#475569;
}

body.dark select:not(.form-field select):not(.select-sm):hover{
  border-color:#3b82f6;background-color:#1e3a5f;
}

body.dark .select-sm{
  background-color:#334155;color:#e2e8f0;border-color:#475569;
}

body.dark .select-sm:hover{
  background-color:#1e3a5f;border-color:#3b82f6;
}

/* ═══════════════════════════════════ RESPONSIVE DESIGN ═══════════════════════════════════ */

/* TABLET SCREENS (640px - 1024px) */
@media (max-width:1024px){
  :root{
    --sidebar-w:200px;
    --topbar-h:56px;
  }
  
  .sidebar{width:var(--sidebar-w)}
  .topbar-brand{width:var(--sidebar-w)}
  .main-wrap{padding-left:calc(32px + var(--sidebar-w))}
  .footer{margin-left:var(--sidebar-w)}
  
  .topbar-search{max-width:250px;margin:0 12px}
  .topbar-right{gap:4px}
  
  .stats-row{grid-template-columns:repeat(2,1fr)}
  .g3{grid-template-columns:repeat(2,1fr)}
  .g4{grid-template-columns:repeat(2,1fr)}
  .g21{grid-template-columns:1fr}
  .g12{grid-template-columns:1fr}
  
  .sb-item{padding:8px 10px;font-size:11px}
  .sb-item .si{font-size:14px}
  
  .page-hdr h1{font-size:18px}
  .stat-val{font-size:24px}
  
  .gal-grid{grid-template-columns:repeat(2,1fr)}
  
  .login-wrapper{width:95vw;min-height:520px}
  .login-right{width:60%;padding:40px 30px}
  .login-left{padding:40px 30px}
  .login-right h2{font-size:20px}
  .role-grid{grid-template-columns:repeat(3,1fr)}
  
  .rc-summary{grid-template-columns:repeat(3,1fr)}
  .rc-student{flex-direction:column;gap:12px}
  .f-row{grid-template-columns:1fr}
}

/* MOBILE SCREENS (480px - 640px) */
@media (max-width:768px){
  :root{
    --sidebar-w:0;
    --topbar-h:56px;
  }
  
  html,body{
    font-size:14px;
    overflow-x:hidden;
    width:100%;
    max-width:100vw;
  }
  
  /* PREVENT HORIZONTAL SCROLLING - but allow tables to scroll */
  html,body,main,nav,.sidebar,.card,.main-wrap,.footer,.page-hdr,.stats-row{
    overflow-x:hidden !important;
    max-width:100vw !important;
  }
  
  /* ALLOW TABLES TO SCROLL HORIZONTALLY */
  .table-wrapper{
    overflow-x:auto !important;
    overflow-y:visible;
    max-width:100% !important;
    width:100% !important;
    box-sizing:border-box !important;
  }
  
  /* TOPBAR ADJUSTMENTS */
  .topbar{padding:0 12px;height:56px;overflow-x:visible;max-width:100vw;}
  .topbar-brand{width:100%;flex:1}
  .topbar-search{display:none}
  .topbar-right{gap:2px}
  .tb-btn{width:36px;height:36px;font-size:14px}
  .tb-avatar{width:36px;height:36px;font-size:12px}
  .brand-mark{width:32px;height:32px;font-size:16px}
  .brand-name{font-size:12px}
  .brand-tag{font-size:8px}
  
  /* SIDEBAR - MOBILE DRAWER */
  .sidebar{
    width:100%;max-width:280px;transform:translateX(-100%);
    transition:transform .3s ease;z-index:300;
    position:fixed;top:var(--topbar-h);left:0;bottom:0;
  }
  
  .sidebar.open{transform:translateX(0)}
  .sidebar.open~.main-wrap::before{
    content:'';position:fixed;inset:0;background:rgba(0,0,0,.5);
    z-index:199;top:var(--topbar-h);
  }
  
  /* MAIN CONTENT */
  .main-wrap{
    padding:16px;padding-top:calc(56px + 16px);margin-left:0;min-height:calc(100vh - 56px);
    overflow-x:hidden;width:100%;max-width:100vw;
  }
  
  /* FOOTER */
  .footer{margin-left:0;flex-direction:column;gap:12px;padding:12px 16px}
  .footer-text{font-size:10px}
  .footer-links{flex-wrap:wrap;gap:12px;justify-content:center}
  .footer-links a{font-size:10px}
  
  /* PAGE HEADER */
  .page-hdr{margin-bottom:18px}
  .page-hdr h1{font-size:20px;margin-bottom:4px}
  .page-hdr p{font-size:11px}
  
  /* STATS */
  .stats-row{grid-template-columns:1fr;gap:12px}
  .stat-card{padding:16px 18px}
  .stat-icon{width:40px;height:40px;font-size:20px;margin-bottom:10px}
  .stat-val{font-size:22px}
  .stat-lbl{font-size:10px}
  .stat-chg{font-size:10px}
  
  /* GRIDS */
  .g2,.g3,.g4,.g21,.g12{grid-template-columns:1fr;gap:12px}
  .mb16{margin-bottom:12px}
  .mb20{margin-bottom:16px}
  .mb24{margin-bottom:18px}
  
  /* CARDS */
  .card{
    padding:16px;
    border-radius:12px;
    overflow:hidden;
    box-sizing:border-box;
    width:100%;
  }
  .card .table-wrapper{
    margin-left:-16px;
    margin-right:-16px;
    margin-bottom:-16px;
    margin-top:0;
    padding:0;
    width:calc(100% + 32px);
    box-sizing:border-box;
    border-radius:0 0 var(--radius-lg) var(--radius-lg);
  }
  .card-hdr{margin-bottom:14px;flex-direction:column;gap:8px}
  .card-title{font-size:13px}
  .card-act{font-size:10px;padding:4px 10px}
  
  /* TABLES */
  .tbl{font-size:11px;width:100% !important;box-sizing:border-box !important}
  .tbl th{padding:6px 6px;font-size:9px}
  .tbl td{padding:6px 6px;font-size:11px}
  .table-wrapper{overflow-x:auto !important;overflow-y:visible !important;max-width:100% !important;box-sizing:border-box !important}
  
  /* BUTTONS */
  .btn{padding:8px 14px;font-size:11px;border-radius:8px}
  .btn-sm{padding:5px 10px;font-size:10px}
  .btn-xs{padding:3px 8px;font-size:9px}
  .back-btn{padding:6px 12px;font-size:11px}
  
  /* FORMS */
  .f-row{grid-template-columns:1fr;gap:10px;margin-bottom:10px}
  .f-field label{font-size:10px}
  .f-field input,.f-field select,.f-field textarea{
    padding:8px 10px;font-size:11px;border-radius:8px;
  }
  .form-grid{grid-template-columns:1fr;gap:10px}
  
  /* LOGIN PAGE */
  #login-page{padding:16px;min-height:100vh}
  .login-wrapper{
    width:100%;max-width:440px;
    padding:32px 20px;
    border-radius:20px;
  }
  .login-wrapper h1{font-size:20px}
  .login-logo-wrap{width:76px;height:76px;margin-bottom:16px;border-radius:18px;padding:8px}
  .role-grid{
    grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:20px;
  }
  .role-btn{padding:12px 6px;border-radius:10px}
  .role-btn .ri{font-size:20px}
  .role-btn .ri i{font-size:20px}
  .role-btn .rl{font-size:9px}
  .login-links{margin-top:10px;font-size:12px}
  
  /* BADGES */
  .badge{padding:2px 8px;font-size:9px}
  
  /* AVATARS */
  .av-sm{width:28px;height:28px;font-size:10px}
  .av-md{width:36px;height:36px;font-size:12px}
  .av-lg{width:48px;height:48px;font-size:16px}
  .av-xl{width:60px;height:60px;font-size:20px}
  
  /* CHARTS */
  .chart-wrap{height:140px}
  
  /* CALENDAR */
  .cal-dname{font-size:8px;padding:2px 0}
  .cal-day{font-size:10px;padding:4px 1px}
